  "scripts": {
    "validate": "bash scripts/validate.sh",
    "lint": "bash scripts/lint-rfcs.sh && markdownlint '**/*.md' --ignore node_modules --ignore CODE_OF_CONDUCT.md"
  },
  "devDependencies": {
    "ajv": "^8.17.0",
    "ajv-cli": "^5.0.0",
    "ajv-formats": "^3.0.1",
    "js-yaml": "^4.1.0",
    "markdownlint-cli": "^0.41.0"
  }
}
