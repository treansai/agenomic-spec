{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentlock.dev/schemas/v0.1/behavior-contract.schema.json",
  "title": "AgentLock Behavior Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "scope",
    "deterministicChecks",
    "probabilisticChecks",
    "releaseGates"
  ],
  "properties": {
    "apiVersion": {
      "const": "agentlock.dev/v0.1"
    },
    "kind": {
      "const": "BehaviorContract"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "description"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{2,63}$"
        },
        "version": {
          "$ref": "#/$defs/semver"
        },
        "description": {
          "type": "string",
          "minLength": 10
        }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bundleName",
        "bundleVersion",
        "criticality"
      ],
      "properties": {
        "bundleName": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{2,63}$"
        },
        "bundleVersion": {
          "$ref": "#/$defs/semver"
        },
        "criticality": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        }
      }
    },
    "deterministicChecks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "description",
          "type",
          "target",
          "enforcement",
          "rule"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]{2,63}$"
          },
          "description": {
            "type": "string",
            "minLength": 10
          },
          "type": {
            "type": "string",
            "enum": [
              "schema_validity",
              "tool_policy",
              "mandatory_approval",
              "output_format",
              "memory_boundary",
              "dependency_constraint"
            ]
          },
          "target": {
            "type": "string",
            "minLength": 3
          },
          "enforcement": {
            "type": "string",
            "enum": [
              "must_pass",
              "warn"
            ]
          },
          "rule": {
            "type": "object"
          }
        }
      }
    },
    "probabilisticChecks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "dimension",
          "description",
          "judge"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]{2,63}$"
          },
          "dimension": {
            "type": "string",
            "enum": [
              "tone",
              "hallucination_risk",
              "answer_quality",
              "policy_interpretation",
              "escalation_judgment"
            ]
          },
          "description": {
            "type": "string",
            "minLength": 10
          },
          "judge": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "method",
              "sampleSize",
              "passThreshold"
            ],
            "properties": {
              "method": {
                "type": "string",
                "enum": [
                  "llm_judge",
                  "human_sample",
                  "hybrid"
                ]
              },
              "model": {
                "type": "string",
                "minLength": 2
              },
              "sampleSize": {
                "type": "integer",
                "minimum": 1
              },
              "passThreshold": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              }
            }
          }
        }
      }
    },
    "releaseGates": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "minimumDeterministicPassRate",
        "minimumProbabilisticPassRate",
        "maxOpenSeverity"
      ],
      "properties": {
        "minimumDeterministicPassRate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "minimumProbabilisticPassRate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "maxOpenSeverity": {
          "type": "string",
          "enum": [
            "none",
            "low",
            "medium",
            "high"
          ]
        }
      }
    },
    "datasets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "description"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]{2,63}$"
          },
          "description": {
            "type": "string",
            "minLength": 10
          }
        }
      }
    }
  },
  "$defs": {
    "semver": {
      "type": "string",
      "pattern": "^([0-9]+)\\.([0-9]+)\\.([0-9]+)(-[0-9A-Za-z.-]+)?(\\+[0-9A-Za-z.-]+)?$"
    }
  }
}
