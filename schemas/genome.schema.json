{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentlock.dev/schemas/v0.1/genome.schema.json",
  "title": "AgentLock Genome",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "purpose",
    "model",
    "prompts",
    "tools",
    "policies",
    "memory",
    "knowledge",
    "eval"
  ],
  "properties": {
    "apiVersion": {
      "const": "agentlock.dev/v0.1"
    },
    "kind": {
      "const": "AgentGenome"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "displayName",
        "version",
        "description",
        "status",
        "owners"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{2,63}$"
        },
        "displayName": {
          "type": "string",
          "minLength": 3
        },
        "version": {
          "$ref": "#/$defs/semver"
        },
        "description": {
          "type": "string",
          "minLength": 10
        },
        "status": {
          "type": "string",
          "enum": [
            "experimental",
            "active",
            "deprecated"
          ]
        },
        "owners": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 2
          }
        }
      }
    },
    "purpose": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "objectives",
        "nonObjectives"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 10
        },
        "objectives": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 5
          }
        },
        "nonObjectives": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 5
          }
        }
      }
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "model",
        "inferenceProfile"
      ],
      "properties": {
        "provider": {
          "type": "string",
          "minLength": 2
        },
        "model": {
          "type": "string",
          "minLength": 2
        },
        "inferenceProfile": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "temperature",
            "topP",
            "maxOutputTokens"
          ],
          "properties": {
            "temperature": {
              "type": "number",
              "minimum": 0,
              "maximum": 2
            },
            "topP": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "maxOutputTokens": {
              "type": "integer",
              "minimum": 1
            }
          }
        }
      }
    },
    "prompts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "systemPromptRef",
        "developerPromptRefs",
        "operatingPrinciples"
      ],
      "properties": {
        "systemPromptRef": {
          "$ref": "#/$defs/artifactRef"
        },
        "developerPromptRefs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/artifactRef"
          }
        },
        "operatingPrinciples": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 5
          }
        }
      }
    },
    "tools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "kind",
          "description",
          "mcp"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]{1,63}$"
          },
          "kind": {
            "const": "mcp"
          },
          "description": {
            "type": "string",
            "minLength": 10
          },
          "mcp": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "serverRef",
              "serverVersion",
              "transport",
              "schemaHash",
              "permissionScopes"
            ],
            "properties": {
              "serverRef": {
                "type": "string",
                "pattern": "^(mcp|urn):.+"
              },
              "serverVersion": {
                "$ref": "#/$defs/semver"
              },
              "transport": {
                "type": "string",
                "enum": [
                  "stdio",
                  "sse",
                  "streamable_http"
                ]
              },
              "schemaHash": {
                "$ref": "#/$defs/sha256"
              },
              "permissionScopes": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "pattern": "^[a-z0-9_.:-]+$"
                }
              }
            }
          }
        }
      }
    },
    "policies": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approvals",
        "dataHandling",
        "toolUse"
      ],
      "properties": {
        "approvals": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "defaultMode",
            "requiredScopes"
          ],
          "properties": {
            "defaultMode": {
              "type": "string",
              "enum": [
                "never",
                "on_policy",
                "on_threshold",
                "always"
              ]
            },
            "requiredScopes": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "pattern": "^[a-z0-9_.:-]+$"
              }
            }
          }
        },
        "dataHandling": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "runtimeMemoryBundling",
            "piiHandling",
            "retentionClass"
          ],
          "properties": {
            "runtimeMemoryBundling": {
              "const": "schema-only"
            },
            "piiHandling": {
              "type": "string",
              "enum": [
                "none",
                "masked",
                "tokenized",
                "forbidden"
              ]
            },
            "retentionClass": {
              "type": "string",
              "enum": [
                "session",
                "thirty_days",
                "ninety_days",
                "regulated_retention"
              ]
            }
          }
        },
        "toolUse": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "allowUnknownTools",
            "maxConcurrentCalls"
          ],
          "properties": {
            "allowUnknownTools": {
              "type": "boolean"
            },
            "maxConcurrentCalls": {
              "type": "integer",
              "minimum": 1
            }
          }
        }
      }
    },
    "memory": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "designMemory",
        "runtimeMemory"
      ],
      "properties": {
        "designMemory": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "schemaRef",
            "version",
            "artifacts"
          ],
          "properties": {
            "schemaRef": {
              "$ref": "#/$defs/artifactRef"
            },
            "version": {
              "$ref": "#/$defs/semver"
            },
            "artifacts": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/artifactRef"
              }
            }
          }
        },
        "runtimeMemory": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "schemaRef",
            "accessPolicyRef",
            "bundleInclusion",
            "compatibilityClass"
          ],
          "properties": {
            "schemaRef": {
              "$ref": "#/$defs/artifactRef"
            },
            "accessPolicyRef": {
              "$ref": "#/$defs/artifactRef"
            },
            "bundleInclusion": {
              "const": "schema-only"
            },
            "compatibilityClass": {
              "type": "string",
              "enum": [
                "backward-compatible",
                "forward-compatible",
                "breaking"
              ]
            }
          }
        }
      }
    },
    "knowledge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "references"
      ],
      "properties": {
        "references": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "description",
              "digest",
              "license",
              "uri"
            ],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9-]{1,63}$"
              },
              "description": {
                "type": "string",
                "minLength": 10
              },
              "digest": {
                "$ref": "#/$defs/sha256"
              },
              "license": {
                "type": "string",
                "minLength": 2
              },
              "uri": {
                "type": "string",
                "minLength": 3
              }
            }
          }
        }
      }
    },
    "eval": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "behaviorContractRef",
        "replayProfile"
      ],
      "properties": {
        "behaviorContractRef": {
          "$ref": "#/$defs/artifactRef"
        },
        "replayProfile": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "sampleCount",
            "variancePolicy"
          ],
          "properties": {
            "sampleCount": {
              "type": "integer",
              "minimum": 1
            },
            "variancePolicy": {
              "type": "string",
              "enum": [
                "fixed_seed",
                "stratified",
                "production_sampled"
              ]
            }
          }
        }
      }
    }
  },
  "$defs": {
    "semver": {
      "type": "string",
      "pattern": "^([0-9]+)\\.([0-9]+)\\.([0-9]+)(-[0-9A-Za-z.-]+)?(\\+[0-9A-Za-z.-]+)?$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "artifactRef": {
      "type": "string",
      "minLength": 3
    }
  }
}
