{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agenomic.dev/spec/v0.3/event-type-registry.json",
  "title": "Agenomic append-only trace event type registry (v0.3)",
  "description": "Enumerated vocabulary for canonical run trace events. required_fields are minimum semantic fields expected when that type appears in schemas/v0.3/trace-event.schema.json.",
  "$defs": {
    "eventType": {
      "type": "string",
      "enum": [
        "run.started",
        "agent.loaded",
        "genome.resolved",
        "prompt.loaded",
        "policy.loaded",
        "memory.read",
        "knowledge.retrieve",
        "llm.requested",
        "llm.responded",
        "decision.made",
        "tool.call.proposed",
        "policy.check.performed",
        "tool.call.approved",
        "tool.call.executed",
        "tool.result.observed",
        "memory.write.proposed",
        "memory.write.committed",
        "human.review.requested",
        "human.review.approved",
        "human.review.rejected",
        "human.review.modified",
        "risk.score.updated",
        "compliance.check.performed",
        "alignment.check.performed",
        "error.raised",
        "run.completed",
        "run.replay.started",
        "run.replay.completed"
      ]
    }
  },
  "event_types": {
    "run.started": {
      "description": "Canonical append-only event run.started.",
      "required_fields": [
        "event_id",
        "type",
        "timestamp",
        "actor",
        "payload_hash",
        "prev_event_hash",
        "event_hash"
