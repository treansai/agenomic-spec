{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentlock.dev/schemas/v0.1/replay-manifest.schema.json",
  "title": "AgentLock Replay Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "bundle",
    "sourceTrace",
    "replayPolicy",
    "cases",
    "comparisons"
  ],
  "properties": {
    "apiVersion": {
      "const": "agentlock.dev/v0.1"
    },
    "kind": {
      "const": "ReplayManifest"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "generatedAt",
        "objective"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{2,63}$"
        },
        "generatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "objective": {
          "type": "string",
          "minLength": 10
        }
      }
    },
    "bundle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "genomeDigest",
        "lockDigest",
        "behaviorContractDigest"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{2,63}$"
        },
        "version": {
          "$ref": "#/$defs/semver"
        },
        "genomeDigest": {
          "$ref": "#/$defs/sha256"
        },
        "lockDigest": {
          "$ref": "#/$defs/sha256"
        },
        "behaviorContractDigest": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "sourceTrace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "traceId",
        "recordedAt",
        "traceDigest"
      ],
      "properties": {
        "traceId": {
          "type": "string",
          "minLength": 8
        },
        "recordedAt": {
          "type": "string",
          "format": "date-time"
        },
        "traceDigest": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "replayPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "sampleCount",
        "seedStrategy",
        "modelVarianceBudget"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "shadow",
            "statistical_compare",
            "compliance_only"
          ]
        },
        "sampleCount": {
          "type": "integer",
          "minimum": 1
        },
        "seedStrategy": {
          "type": "string",
          "enum": [
            "fixed",
            "rotate",
            "production_bucket"
          ]
        },
        "modelVarianceBudget": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "description",
          "inputDigest",
          "expectedDeterministicChecks",
          "expectedToolSequence"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]{2,63}$"
          },
          "description": {
            "type": "string",
            "minLength": 10
          },
          "inputDigest": {
            "$ref": "#/$defs/sha256"
          },
          "expectedDeterministicChecks": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 2
            }
          },
          "expectedToolSequence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 2
            }
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "comparisons": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "outputSimilarity",
        "toolSelectionAgreement",
        "approvalOutcomeAgreement",
        "policyViolationRate"
      ],
      "properties": {
        "outputSimilarity": {
          "$ref": "#/$defs/comparisonRule"
        },
        "toolSelectionAgreement": {
          "$ref": "#/$defs/comparisonRule"
        },
        "approvalOutcomeAgreement": {
          "$ref": "#/$defs/comparisonRule"
        },
        "policyViolationRate": {
          "$ref": "#/$defs/comparisonRule"
        }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mcpServers": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "serverRef",
              "version",
              "schemaHash"
            ],
            "properties": {
              "serverRef": {
                "type": "string",
                "pattern": "^(mcp|urn):.+"
              },
              "version": {
                "$ref": "#/$defs/semver"
              },
              "schemaHash": {
                "$ref": "#/$defs/sha256"
              }
            }
          }
        },
        "datasets": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "digest"
            ],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9-]{2,63}$"
              },
              "digest": {
                "$ref": "#/$defs/sha256"
              }
            }
          }
        }
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "reportFormat": {
          "type": "string",
          "enum": [
            "json",
            "yaml",
            "html"
          ]
        },
        "artifactPaths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 3
          }
        }
      }
    }
  },
  "$defs": {
    "semver": {
      "type": "string",
      "pattern": "^([0-9]+)\\.([0-9]+)\\.([0-9]+)(-[0-9A-Za-z.-]+)?(\\+[0-9A-Za-z.-]+)?$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "comparisonRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metric",
        "threshold"
      ],
      "properties": {
        "metric": {
          "type": "string",
          "minLength": 3
        },
        "threshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    }
  }
}
