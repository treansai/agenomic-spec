{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentlock.dev/schemas/v0.1/release-attestation.schema.json",
  "title": "AgentLock Release Attestation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "subject",
    "statement",
    "evidence",
    "approvals",
    "signatures"
  ],
  "properties": {
    "apiVersion": {
      "const": "agentlock.dev/v0.1"
    },
    "kind": {
      "const": "ReleaseAttestation"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "attestationVersion",
        "generatedAt",
        "issuer"
      ],
      "properties": {
        "attestationVersion": {
          "$ref": "#/$defs/semver"
        },
        "generatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "issuer": {
          "type": "string",
          "minLength": 2
        }
      }
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bundleName",
        "bundleVersion",
        "digests"
      ],
      "properties": {
        "bundleName": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{2,63}$"
        },
        "bundleVersion": {
          "$ref": "#/$defs/semver"
        },
        "digests": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "genome",
            "lock",
            "behaviorContract"
          ],
          "properties": {
            "genome": {
              "$ref": "#/$defs/sha256"
            },
            "lock": {
              "$ref": "#/$defs/sha256"
            },
            "behaviorContract": {
              "$ref": "#/$defs/sha256"
            }
          }
        }
      }
    },
    "statement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "releaseStatus",
        "summary",
        "replayResult",
        "approvedBy"
      ],
      "properties": {
        "releaseStatus": {
          "type": "string",
          "enum": [
            "candidate",
            "approved",
            "rejected",
            "rolled_back"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 10
        },
        "replayResult": {
          "type": "string",
          "enum": [
            "pass",
            "fail",
            "mixed"
          ]
        },
        "approvedBy": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 2
          }
        },
        "validUntil": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "replayManifestDigest",
        "traceSetDigest",
        "approvalRecordDigest"
      ],
      "properties": {
        "replayManifestDigest": {
          "$ref": "#/$defs/sha256"
        },
        "traceSetDigest": {
          "$ref": "#/$defs/sha256"
        },
        "approvalRecordDigest": {
          "$ref": "#/$defs/sha256"
        },
        "notesDigest": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "approvals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "approverRole",
          "decision",
          "rationaleDigest"
        ],
        "properties": {
          "approverRole": {
            "type": "string",
            "minLength": 2
          },
          "decision": {
            "type": "string",
            "enum": [
              "approved",
              "rejected",
              "conditional"
            ]
          },
          "rationaleDigest": {
            "$ref": "#/$defs/sha256"
          }
        }
      }
    },
    "signatures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "keyId",
          "algorithm",
          "signature",
          "signedAt"
        ],
        "properties": {
          "keyId": {
            "type": "string",
            "minLength": 3
          },
          "algorithm": {
            "type": "string",
            "enum": [
              "ed25519",
              "ecdsa-p256",
              "rsa-pss-sha256"
            ]
          },
          "signature": {
            "type": "string",
            "minLength": 16
          },
          "signedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  },
  "$defs": {
    "semver": {
      "type": "string",
      "pattern": "^([0-9]+)\\.([0-9]+)\\.([0-9]+)(-[0-9A-Za-z.-]+)?(\\+[0-9A-Za-z.-]+)?$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    }
  }
}
