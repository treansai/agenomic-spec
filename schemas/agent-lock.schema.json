{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentlock.dev/schemas/v0.1/agent-lock.schema.json",
  "title": "AgentLock Lockfile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "bundle",
    "digests",
    "resolvedArtifacts",
    "compatibility",
    "provenance"
  ],
  "properties": {
    "apiVersion": {
      "const": "agentlock.dev/v0.1"
    },
    "kind": {
      "const": "AgentLock"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "specVersion",
        "generatedAt"
      ],
      "properties": {
        "specVersion": {
          "$ref": "#/$defs/semver"
        },
        "generatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "bundle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{2,63}$"
        },
        "version": {
          "$ref": "#/$defs/semver"
        }
      }
    },
    "digests": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "genome",
        "behaviorContract"
      ],
      "properties": {
        "genome": {
          "$ref": "#/$defs/sha256"
        },
        "behaviorContract": {
          "$ref": "#/$defs/sha256"
        },
        "replayManifest": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "resolvedArtifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prompts",
        "tools",
        "knowledge",
        "designMemory"
      ],
      "properties": {
        "prompts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "path",
              "digest"
            ],
            "properties": {
              "path": {
                "type": "string",
                "minLength": 3
              },
              "digest": {
                "$ref": "#/$defs/sha256"
              }
            }
          }
        },
        "tools": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "serverRef",
              "serverVersion",
              "schemaHash",
              "permissionScopes"
            ],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9-]{1,63}$"
              },
              "serverRef": {
                "type": "string",
                "pattern": "^(mcp|urn):.+"
              },
              "serverVersion": {
                "$ref": "#/$defs/semver"
              },
              "schemaHash": {
                "$ref": "#/$defs/sha256"
              },
              "permissionScopes": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "pattern": "^[a-z0-9_.:-]+$"
                }
              }
            }
          }
        },
        "knowledge": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "digest"
            ],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9-]{1,63}$"
              },
              "digest": {
                "$ref": "#/$defs/sha256"
              }
            }
          }
        },
        "designMemory": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "schemaRef",
              "version",
              "digest"
            ],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9-]{1,63}$"
              },
              "schemaRef": {
                "type": "string",
                "minLength": 3
              },
              "version": {
                "$ref": "#/$defs/semver"
              },
              "digest": {
                "$ref": "#/$defs/sha256"
              }
            }
          }
        }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtimeMemorySchema",
        "rollback"
      ],
      "properties": {
        "runtimeMemorySchema": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "currentVersion",
            "compatibleWith",
            "breakingChanges"
          ],
          "properties": {
            "currentVersion": {
              "$ref": "#/$defs/semver"
            },
            "compatibleWith": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/semver"
              }
            },
            "breakingChanges": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 3
              }
            }
          }
        },
        "rollback": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "allowedBundleVersions",
            "blockedWhen",
            "dependencyConstraints"
          ],
          "properties": {
            "allowedBundleVersions": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/semver"
              }
            },
            "blockedWhen": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 3
              }
            },
            "dependencyConstraints": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "component",
                  "constraint"
                ],
                "properties": {
                  "component": {
                    "type": "string",
                    "minLength": 2
                  },
                  "constraint": {
                    "type": "string",
                    "minLength": 2
                  }
                }
              }
            }
          }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lockGenerator",
        "sourceCommit",
        "createdBy"
      ],
      "properties": {
        "lockGenerator": {
          "type": "string",
          "minLength": 3
        },
        "sourceCommit": {
          "type": "string",
          "pattern": "^[a-f0-9]{7,64}$"
        },
        "createdBy": {
          "type": "string",
          "minLength": 2
        }
      }
    }
  },
  "$defs": {
    "semver": {
      "type": "string",
      "pattern": "^([0-9]+)\\.([0-9]+)\\.([0-9]+)(-[0-9A-Za-z.-]+)?(\\+[0-9A-Za-z.-]+)?$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    }
  }
}
