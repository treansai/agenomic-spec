# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.{json,yaml,yml}]
indent_size = 2

[*.md]
indent_size = 4
trim_trailing_whitespace = false

[*.{sh,bash}]
indent_size = 2

[Makefile]
indent_style = tab
